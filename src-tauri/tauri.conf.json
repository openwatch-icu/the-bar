{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "the-bar",
  "version": "0.1.0",
  "identifier": "app.the-bar.chat",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd web && npm run dev",
    "beforeBuildCommand": "cd web && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "The Bar",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/thebar-server"]
  }
}
