# Server configuration (optional; defaults shown)
#
# Typically enabled for a real deployment:
#   ACCESS_CODE=...          (required; set a 16+ char code)
#   PERSIST_MESSAGES=true    (default; keep history across restarts)
#   TLS_HTTP_ENABLE=1        (if serving over HTTPS)
#   TLS_CERT_FILE / TLS_KEY_FILE
#   REDUCE_LOG_RATE=1        (if logs are noisy or rate-limited)
#   ALLOW_JOIN_WITHOUT_TOKEN=1  (optional; with "Forget my session" in UI)
# Leave defaults for: DATA_DIR, TCP/HTTP ports, timeouts, BAR, scalability vars unless tuning.
#
# DATA_DIR=./chatdata
# INSTANCE_SLUG=default
# TCP_ADDR=:9000
# HTTP_ADDR=:8080
# ALLOWED_ORIGINS=https://your-frontend.example.com  (tauri://localhost and http://localhost:5173 are always allowed for desktop and local dev)

# Required: access code to join this instance (invite-only). Must be at least 16 characters.
# Generate a strong random code: openssl rand -base64 24  (or openssl rand -hex 16). Share only over a secure channel.
# ACCESS_CODE=

# Load test (k6): set when running scripts/load. Use: docker run --env-file .env ... (scripts read WS_URL and ACCESS_CODE from env).
# WS_URL=wss://your-server.example.com/bar/ws

# Minimum age for this server (0 = no restriction; clients must confirm age when > 0). Default 18. Configurable by host.
# MINIMUM_AGE=18

# TLS (optional). For LAN access with HTTPS, cert must include your LAN IP in SAN (see README "TLS on LAN").
# TLS_HTTP_ENABLE=1
# TLS_TCP_ENABLE=0
# TLS_CERT_FILE=/path/to/cert.pem
# TLS_KEY_FILE=/path/to/key.pem

# Testing only: enable /simulate crash
# ENABLE_SIMULATE_CRASH=0

# Inactivity and timeouts (minutes). INACTIVITY_DISCONNECT_MINUTES: disconnect client after this many minutes of inactivity.
# READ_DEADLINE_MINUTES: if no message from client for this long, server may close connection. Set to 0 to disable (no read timeout).
# WRITE_DEADLINE_SECONDS: max time in seconds to write a single WebSocket frame to a client before the connection is dropped (default 30). Lower values (e.g. 10) detect dead clients faster.
# SESSION_MAX_AGE_HOURS: absolute session lifetime in hours regardless of activity; token is invalidated after this time and user must re-join (0 = no limit; default 24).
# INACTIVITY_DISCONNECT_MINUTES=5
# IDLE_LABEL_MINUTES=1
# READ_DEADLINE_MINUTES=5
# WRITE_DEADLINE_SECONDS=30
# SESSION_MAX_AGE_HOURS=24

# Message history retention (days; 0 = keep forever). Older messages are pruned and snapshot rewritten.
# HISTORY_RETENTION_DAYS=0

# BAR (Burn After Reading). When BAR_USER_ALLOWED=true and SESSION_BAR_MINUTES=0, only users who set a BAR at join have messages pruned (user BAR only).
# When SESSION_BAR_MINUTES > 0, session-wide BAR applies; user BAR is capped by min(SESSION_BAR_MINUTES, USER_BAR_MAX_MINUTES).
# USER_BAR_MAX_MINUTES: cap for user-set BAR when BAR_USER_ALLOWED=true (default 2880 = 2 days; hard cap 30 days).
# BAR_USER_ALLOWED=false
# SESSION_BAR_MINUTES=0
# USER_BAR_MAX_MINUTES=2880

# Session and message caps. MAX_SESSIONS: hard cap on concurrent sessions; new joins are rejected with "server at capacity" when reached (0 = unlimited; default 10000).
# MAX_MESSAGES: max messages kept in memory and written to snapshot; older messages are trimmed on snapshot (0 = unlimited). Useful to bound memory on long-running instances.
# MAX_SESSIONS=10000
# MAX_MESSAGES=0

# Message persistence. When false, server runs in memory-only (no WAL/snapshot); restarts lose room history.
# PERSIST_MESSAGES=true (default). Set to 0 or false to disable saving message history to disk.
# PERSIST_MESSAGES=true

# Optional logging (privacy): set to 0 or false to reduce what is written to stdout (e.g. Docker logs).
# The server never logs or has access to connection addresses (IPs). LOG_BROADCAST_BODY=1 (default): when 0/false, do not log message body in broadcast lines.
# LOG_BROADCAST_BODY=1

# Reduce log rate: set to 1 or true to stop logging each "Broadcasting to..." and "Skipped ... (channel full)" line. Use when hitting platform log rate limits (e.g. Railway). [loadstats] still logs every 10s.
# REDUCE_LOG_RATE=0

# Join worker pool: number of goroutines that process new connections in parallel (default 1). Set to 4–8 for high-traffic instances to reduce join latency under connection spikes. Max 64.
# JOIN_WORKERS=1

# Scalability: channel buffer sizes and workers for 9k+ concurrent users. Buffered channels prevent connection goroutines from blocking on the central Run loop.
# BROADCAST_CHANNEL_BUFFER=10000
# BROADCAST_WORKERS=1
# LEAVE_CHANNEL_BUFFER=1000
# SWITCH_ROOM_CHANNEL_BUFFER=1000
# LIST_USERS_CHANNEL_BUFFER=1000
# DIRECT_MESSAGE_CHANNEL_BUFFER=1000
# CLIENT_OUTGOING_BUFFER=256
# WAL_BATCH_SIZE=100
# WAL_SYNC_INTERVAL_MS=1000

# Slowmode: cooldown in seconds between messages per user per room (0 = disabled). Server sends "slowmode:N" so client can show "You can send again in Ns".
# SLOWMODE_SECONDS=0
# Rate limit: max chat messages per second per user (0 = disabled). Server sends "Rate limited. Try again in a moment."
# RATE_LIMIT_PER_SEC=0
# Global rate limit: max chat messages per second across ALL users combined (0 = disabled). Acts as a server-wide throughput ceiling to cap flood damage. Recommended for public instances (e.g. 200).
# GLOBAL_RATE_LIMIT_PER_SEC=0

# WebSocket keepalive: server sends Ping frames every N seconds so proxies do not close idle connections.
# WS_PING_INTERVAL_SECONDS=25

# I2P (optional). When I2P_ENABLE=1, the server also listens on I2P via the SAM bridge. Requires an I2P router (e.g. i2pd) with SAM enabled.
# I2P_ENABLE=0
# I2P_SAM_ADDRESS=127.0.0.1:7656
# I2P_SESSION_NAME=thebar

# Join without token: when 1 or true, if user sends plain username (no reconnect) and no one is currently connected with that name, allow join and issue new token. Trade-off: anyone can claim the name when owner is offline. Use with "Forget my session" in the UI.
# ALLOW_JOIN_WITHOUT_TOKEN=0

# Testing only: enable /reset-sessions (clears all sessions so new names can join)
# ENABLE_RESET_SESSIONS=0

# License check at startup (optional). For commercial use you need a license from the copyright holder.
# If set, server validates LICENSE_KEY with LICENSE_SERVER_URL before starting.
# Set DISABLE_LICENSE_CHECK=1 to skip (e.g. for dev). LICENSE_KEY_FILE can be used instead of LICENSE_KEY (path to file containing the key).
# LICENSE_SERVER_URL=https://your-license-validation-url.example.com
# LICENSE_KEY=your-license-key
# DISABLE_LICENSE_CHECK=0
