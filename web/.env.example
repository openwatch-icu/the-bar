# Chat server URL (Go backend), NOT the Vite dev server.
# Default: http://localhost:8080 — use this when the Go server runs on :8080.
# Do NOT use http://localhost:5173 (that is the Vite dev server; WebSocket will hang).
# Web dev: read when you run `npm run dev`. Desktop app: baked in at build time (rebuild after changing).
VITE_WS_URL=http://localhost:8080

# Instance slug when not using path (e.g. open app at / instead of /private)
# Default: "default". If you open http://localhost:5173/private, slug is taken from the path.
VITE_INSTANCE_SLUG=default

# Base path for the chat app (e.g. /bar when app is at /bar and /bar/:slug).
# Set to /bar when using path-based routing so instance slug is parsed correctly from the URL.
# Leave unset or empty when the app is served at root (e.g. future bar.yourdomain.com deploy).
VITE_APP_BASE_PATH=/bar
